# -------------------------------------------------------
# Bico Brasil — Environment Variables Template
# Copy this file to .env and fill in the real values.
# NEVER commit the .env file with real credentials.
# -------------------------------------------------------

# --- Frontend (Vite) — exposed in browser bundle ---
# These are public by design; do NOT put secrets here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Mercado Pago public key (safe for frontend)
VITE_MERCADOPAGO_PUBLIC_KEY=

# VAPID public key for Web Push notifications (safe for frontend)
VITE_VAPID_PUBLIC_KEY=

# Optional: injected by CI to identify build
VITE_APP_BUILD_ID=

# --- Backend / Supabase Edge Functions ---
# Set these as Supabase Secrets, NOT in .env files.
# supabase secrets set KEY=value
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
RESEND_API_KEY=
